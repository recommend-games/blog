SNOOKER_API_HEADER= # Follow instructions from https://api.snooker.org/

# BGA spider (bga_spider.py)
DOWNLOAD_DELAY=10
RESULTS_DIR=results
JOBDIR=.jobs
CONCURRENT_REQUESTS_PER_DOMAIN=16
FEED_EXPORT_BATCH_ITEM_COUNT=100000
SCRAPE_RANKINGS=false
SCRAPE_MATCHES=true
PRIORITISE_POPULAR_GAMES=true
MAX_MATCHES_PER_PAGE=5000
# MAX_RANK_SCRAPED=          # optional; cap ranks scraped per game (e.g. 1000)
# ALLOW_LIST_IDS=           # optional; comma-separated game IDs to scrape only (e.g. 12345,67890)
